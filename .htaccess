RewriteEngine On

# --------------------------------------------------
# HARDENING BÁSICO
# --------------------------------------------------
Options -Indexes -MultiViews

# --------------------------------------------------
# PERMITIR .well-known
# --------------------------------------------------
RewriteRule ^\.well-known/ - [L]

# --------------------------------------------------
# FORZAR HTTPS
# Compatible con servidor directo o proxy/CDN
# --------------------------------------------------
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --------------------------------------------------
# OCULTAR index.php / index
# --------------------------------------------------
RewriteRule ^(.*/)?index\.php$ /$1 [R=301,L]
RewriteRule ^(.*/)?index$ /$1 [R=301,L]

# --------------------------------------------------
# FORZAR URLS SIN .php
# Evita duplicados tipo /contacto y /contacto.php
# --------------------------------------------------
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php(?:[\s?]|$) [NC]
RewriteRule ^ %1 [R=301,L]

# --------------------------------------------------
# QUITAR SLASH FINAL EN ARCHIVOS
# No afecta directorios reales
# --------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# --------------------------------------------------
# RESOLVER URL LIMPIA A .php
# /contacto -> /contacto.php
# --------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# --------------------------------------------------
# RESOLVER CARPETAS A index.php
# /infraestructura -> /infraestructura/index.php
# --------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}/index.php -f
RewriteRule ^(.+)$ $1/index.php [L]

# --------------------------------------------------
# 404 CUSTOM
# --------------------------------------------------
ErrorDocument 404 /404

# --------------------------------------------------
# BLOQUEAR ACCESO A DIRECTORIOS INTERNOS
# --------------------------------------------------
RewriteRule ^config(?:/|$) - [F,L,NC]
RewriteRule ^includes(?:/|$) - [F,L,NC]

# --------------------------------------------------
# BLOQUEAR ARCHIVOS SENSIBLES
# --------------------------------------------------
<FilesMatch "^(config\.php|bootstrap\.php|functions\.php|seo\.php)$">
    Require all denied
</FilesMatch>

# --------------------------------------------------
# CACHE PARA ASSETS
# --------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|webp|png|jpe?g|svg|ico|woff2?|ttf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# --------------------------------------------------
# COMPRESIÓN
# --------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>